---
import CarbonBadge from "@/components/carbon-badge.astro";
import ColophonPage from "@/components/colophon-page";
import Layout from "@/layouts/layout.astro";
import { createPageMetadata, formatPageTitle } from "@/lib/metadata";

const pageMeta = createPageMetadata({
  description:
    "Typography, technical stack, and inspiration behind zacchary.me. Built with Astro, React, Directus, and Tailwind, deployed on Cloudflare Workers.",
  path: "/colophon",
  title: "Colophon",
});

const fullTitle = formatPageTitle("Colophon");
---

<Layout
  canonicalUrl={pageMeta.alternates?.canonical}
  fullTitle={fullTitle}
  meta={pageMeta}
>
  <ColophonPage />
  <CarbonBadge />
</Layout>
