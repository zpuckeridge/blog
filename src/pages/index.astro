---
export const prerender = true;

import AnimatedGradientText from "@/components/animated-gradient-text.astro";
import BrisbaneDateTime from "@/components/brisbane-datetime.astro";
import ContributionsGraphStatic from "@/components/contributions-graph-static.astro";
import GitHubContributions from "@/components/contributions-graph";
import Layout from "@/layouts/layout.astro";
import LanyardStatus from "@/components/lanyard-status.astro";
import LinkWithIcon from "@/components/link-with-icon.astro";
import ToggleTheme from "@/components/toggle-theme.astro";
import {
  createPageMetadata,
  formatPageTitle,
} from "@/lib/metadata";
import { getPosts, getProjects } from "@/lib/directus-content";
import {
  fetchGitHubContributions,
  getCachedGitHubContributions,
  getGitHubToken,
} from "@/lib/github-contributions";
import type { ContributionDay } from "@/lib/github-contributions";

const [posts, projects] = await Promise.all([getPosts(), getProjects()]);
const sortedPosts = posts.toSorted(
  (a, b) =>
    new Date(b.date_created).getTime() - new Date(a.date_created).getTime()
);
const sortedProjects = projects.toSorted((a, b) => {
  if (a.status === "work_in_progress" && b.status !== "work_in_progress") {
    return -1;
  }
  if (a.status !== "work_in_progress" && b.status === "work_in_progress") {
    return 1;
  }
  if (a.status === "archived" && b.status !== "archived") {
    return 1;
  }
  if (a.status !== "archived" && b.status === "archived") {
    return -1;
  }
  if (a.year_completed && b.year_completed) {
    return b.year_completed - a.year_completed;
  }
  if (a.year_completed && !b.year_completed) {
    return -1;
  }
  if (!a.year_completed && b.year_completed) {
    return 1;
  }
  return (
    new Date(b.date_created).getTime() - new Date(a.date_created).getTime()
  );
});
const githubUsername = "zpuckeridge";
const githubContributions = await (async (): Promise<
  ContributionDay[] | undefined
> => {
  const cachedContributions = getCachedGitHubContributions(githubUsername);
  if (cachedContributions) {
    return cachedContributions;
  }

  const token = getGitHubToken();
  if (!token) {
    return undefined;
  }

  try {
    return await fetchGitHubContributions(token, githubUsername);
  } catch (error) {
    console.error("Failed to preload GitHub contributions", error);
    return undefined;
  }
})();
const currentYear = new Date().getFullYear();

const pageMeta = createPageMetadata({
  description:
    "Self-taught Web Developer & Generalist. Based in Brisbane, Australia.",
  path: "/",
  title: "Home",
});

const fullTitle = formatPageTitle("Home");
---

<Layout
  canonicalUrl={pageMeta.alternates?.canonical}
  fullTitle={fullTitle}
  meta={pageMeta}
  rootDefaults
>
  <div class="mx-auto flex max-w-lg flex-col gap-4 px-6 pb-20">
    <div class="space-y-10">
      <div class="space-y-4">
        <div class="space-y-2 text-sm">
          <p class="font-redaction text-xl text-black dark:text-white">
            Zacchary Puckeridge
          </p>
          <div>
            <p>Self-taught Web Developer & Generalist</p>
            <p>Based in Brisbane, Australia</p>
          </div>
        </div>

        <div class="flex flex-col gap-4 md:flex-row md:justify-between">
          <div class="-ml-1 flex flex-row gap-2 text-sm text-muted-foreground">
            <LinkWithIcon href="https://x.com/zpuckeridge/" variant="default">
              X
            </LinkWithIcon>
            <LinkWithIcon
              href="https://www.facebook.com/zpuckeridge/"
              variant="default"
            >
              Facebook
            </LinkWithIcon>
            <LinkWithIcon
              href="https://www.instagram.com/zpuckeridge/"
              variant="default"
            >
              Instagram
            </LinkWithIcon>
            <LinkWithIcon
              href="https://www.linkedin.com/in/zpuckeridge/"
              variant="default"
            >
              LinkedIn
            </LinkWithIcon>
            <LinkWithIcon href="https://github.com/zpuckeridge" variant="default">
              GitHub
            </LinkWithIcon>
          </div>

          <div>
            <p class="text-nowrap text-sm text-muted-foreground">
              &copy; {currentYear}
            </p>
          </div>
        </div>
      </div>

      <div class="space-y-10">
        <hr class="border-dotted border-border" />

        <div class="flex flex-row items-baseline gap-4 text-sm leading-normal">
          <div class="w-20 shrink-0">
            <p class="text-muted-foreground">Now</p>
          </div>

          <div class="w-full space-y-2">
            <p>
              IT Operations Lead for{" "}
              <LinkWithIcon href="https://www.starcompass.com.au">
                Star Compass
              </LinkWithIcon>
              , a disability support service and{" "}
              <LinkWithIcon href="https://www.haddoninstitute.org">
                Haddon Institute
              </LinkWithIcon>
              , a distinctly Reformed seminary.
            </p>
            <p>
              I also run a web design studio known as{" "}
              <LinkWithIcon href="https://obambulo.studio">
                obambulo studio
              </LinkWithIcon>
              . I have limited availability, but I am open to hearing about your
              project!
            </p>
          </div>
        </div>

        <div class="flex flex-row items-baseline gap-4 text-sm leading-normal">
          <div class="w-20 shrink-0">
            <p class="text-muted-foreground">Prev</p>
          </div>

          <div class="w-full space-y-2">
            <p>
              Previously, I was working for{" "}
              <LinkWithIcon href="https://www.rsp.com.au">
                Rising Sun Pictures
              </LinkWithIcon>{" "}
              (2022 <span aria-hidden="true" class="inline-block align-[-0.125em]">→</span> 2024) as an
              IT Administrator to deploy and maintain the remote Brisbane office
              infrastructure.
            </p>

            <p>
              Prior to that, I worked for{" "}
              <LinkWithIcon href="https://www.pixelzoo.com.au">
                Pixel Zoo
              </LinkWithIcon>{" "}
              (2021 <span aria-hidden="true" class="inline-block align-[-0.125em]">→</span> 2022) as a
              Systems Administrator to provide internal and remote support for
              ~200+ employees. Deployed various networking and hardware upgrades
              across the studio and implemented new file storage infrastructure.
            </p>

            <p class="text-sm text-muted-foreground">
              You can find my full employment history{" "}
              <a
                class="group inline bg-muted px-1 leading-[inherit] hover:bg-muted/80"
                href="/cv"
              >here</a>.
            </p>
          </div>
        </div>

        <div class="space-y-10 border-t border-dotted border-border pt-10">
          <div class="space-y-2">
            <div class="flex w-full flex-row items-baseline gap-4 text-sm leading-normal">
              <div class="w-20 shrink-0">
                <p class="text-muted-foreground">Timeline</p>
              </div>

              <div
                class="relative flex h-36 w-full flex-col gap-1 overflow-y-hidden"
              >
                {sortedPosts.slice(0, 7).map((post) => (
                  <a
                    aria-label={post.title}
                    class="flex justify-between gap-4 px-1 hover:bg-muted"
                    href={`/timeline/${post.slug}`}
                  >
                    <p class="line-clamp-1">{post.title}</p>
                    <p class="text-muted-foreground">
                      {new Date(post.date_created).toLocaleDateString(
                        undefined,
                        {
                          day: "2-digit",
                          month: "2-digit",
                          year: "numeric",
                        }
                      )}
                    </p>
                  </a>
                ))}
                <div
                  class="pointer-events-none absolute inset-x-0 bottom-0 z-40 h-20 bg-linear-to-t from-white dark:from-background"
                />
              </div>
            </div>
            <div class="flex justify-end">
              <a
                class="text-sm text-muted-foreground px-1 hover:bg-muted"
                href="/timeline"
              >
                See all {sortedPosts.length}
              </a>
            </div>
          </div>

          <div class="space-y-2">
            <div class="flex w-full flex-row items-baseline gap-4 text-sm leading-normal">
              <div class="w-20 shrink-0">
                <p class="text-muted-foreground">Projects</p>
              </div>
              <div
                class="relative flex h-36 w-full flex-col gap-1 overflow-y-hidden"
              >
                {sortedProjects.slice(0, 7).map((project) => {
                  const yearLabel =
                    project.status === "work_in_progress"
                      ? null
                      : project.year_completed || "Present";

                  const trailingLabel =
                    project.status === "work_in_progress" ? (
                      <AnimatedGradientText text="WIP" />
                    ) : (
                      <span class="text-muted-foreground">{yearLabel}</span>
                    );

                  if (project.link && project.status !== "work_in_progress") {
                    return (
                      <a
                        class="flex justify-between gap-4 px-1 hover:bg-muted"
                        href={project.link}
                        rel="noopener noreferrer"
                        target="_blank"
                      >
                        <span class="line-clamp-1">{project.name}</span>
                        {trailingLabel}
                      </a>
                    );
                  }

                  return (
                    <div class="flex justify-between gap-4 px-1">
                      <span class="line-clamp-1">{project.name}</span>
                      {trailingLabel}
                    </div>
                  );
                })}
                <div
                  class="pointer-events-none absolute inset-x-0 bottom-0 z-40 h-20 bg-linear-to-t from-white dark:from-background"
                />
              </div>
            </div>
            <div class="flex justify-end">
              <a
                class="text-sm text-muted-foreground px-1 hover:bg-muted"
                href="/projects"
              >
                See all {projects.length}
              </a>
            </div>
          </div>
        </div>

        <hr class="border-dotted border-border" />

        {
          githubContributions ? (
            <ContributionsGraphStatic contributions={githubContributions} />
          ) : (
            <GitHubContributions
              client:visible
              username={githubUsername}
            />
          )
        }

        <hr class="border-dotted border-border" />

        <div class="space-y-4">
          <div class="flex justify-between">
            <BrisbaneDateTime />
            <LanyardStatus />
          </div>
          <p class="text-sm text-muted-foreground">
            Waging war on weak culture, building digital strongholds, sharpening
            minds, and advancing the Kingdom of God.
          </p>

          <div class="flex justify-between gap-4">
            <div class="-ml-1 flex flex-row gap-2 text-sm text-muted-foreground">
              <a class="inline-flex px-1 hover:bg-muted" href="/colophon">
                Colophon
              </a>
              <span>•</span>
              <a class="inline-flex px-1 hover:bg-muted" href="/imprint">
                Imprint
              </a>
            </div>

            <ToggleTheme />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
